<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permisos (nota: READ/WRITE_EXTERNAL_STORAGE están deprecados en API 33+, mantenidos si aún los necesitas) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:name=".TodoAcordeApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"

    android:theme="@style/Theme.TodoAcorde.EdgeToEdge"

    tools:targetApi="31">

    <!-- Servicio de monitorización de la app -->
    <service
        android:name=".AppMonitorService"
        android:enabled="true"
        android:exported="true" />

    <!-- Actividad principal -->
    <activity
        android:name=".MainContainerActivity"
        android:exported="true"
        android:screenOrientation="portrait">

        <!--
          Si prefieres aplicar el tema sólo en esta Activity en lugar de toda la app,
          mueve el android:theme de <application> a aquí.
          Ejemplo:
          android:theme="@style/Theme.TodoAcorde.EdgeToEdge"
        -->

        <intent-filter>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
    </activity>

    <!-- Ejemplo de Activity antigua con AppCompat (si la usas):
    <activity
        android:name=".LegacyActivity"
        android:theme="@style/Theme.TodoAcorde.AppCompat"
        android:exported="false" />
    -->
</application>
    </manifest>
