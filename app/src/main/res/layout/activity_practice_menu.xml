<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Botón para seleccionar la canción "House of the Rising Sun" -->
    <Button
        android:id="@+id/btnHouseOfRisingSun"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="House of the Rising Sun"
        android:textSize="18sp"
        android:layout_marginBottom="10dp" />

    <!-- Otros botones para clasificaciones (Placeholder) -->
    <Button
        android:id="@+id/btnClassification1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clasificación 1"
        android:textSize="18sp"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btnClassification2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clasificación 2"
        android:textSize="18sp"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btnClassification3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clasificación 3"
        android:textSize="18sp"
        android:layout_marginBottom="10dp" />

</LinearLayout>
