<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:fontFamily="sans-serif">

    <!-- Toolbar sin texto -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarMetronome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- BPM Display: Sans Serif Bold 32sp -->
    <TextView
        android:id="@+id/tvBpm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="100 BPM"
        android:textSize="32sp"
        android:fontFamily="sans-serif"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        app:layout_constraintTop_toBottomOf="@id/toolbarMetronome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <!-- Botón “-” más grande -->
    <ImageButton
        android:id="@+id/btnDecrease"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/ic_remove_circle_outline_24"
        android:tint="?attr/colorPrimary"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvBpm"
        android:layout_marginTop="24dp"
        android:contentDescription="Disminuir BPM" />

    <!-- SeekBar más alto -->
    <SeekBar
        android:id="@+id/seekBarBpm"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:max="218"
        android:progress="100"
        android:splitTrack="false"
        android:thumbTint="?attr/colorPrimary"
        android:progressTint="?attr/colorPrimary"
        app:layout_constraintTop_toTopOf="@id/btnDecrease"
        app:layout_constraintBottom_toBottomOf="@id/btnDecrease"
        app:layout_constraintStart_toEndOf="@id/btnDecrease"
        app:layout_constraintEnd_toStartOf="@id/btnIncrease" />

    <!-- Botón “+” más grande -->
    <ImageButton
        android:id="@+id/btnIncrease"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/ic_add_circle_outline_24"
        android:tint="?attr/colorPrimary"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnDecrease"
        android:contentDescription="Aumentar BPM" />

    <!-- Selector de compás -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupTimeSignature"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:chipSpacing="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnDecrease"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp">

        <com.google.android.material.chip.Chip
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:id="@+id/chip2_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2/4"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.chip.Chip
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:id="@+id/chip3_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3/4"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.chip.Chip
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:id="@+id/chip4_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4/4"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.chip.Chip
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:id="@+id/chip6_8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6/8"
            android:fontFamily="sans-serif-medium" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Toggle primer tiempo -->
    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchAccentFirst"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Marcar primer tiempo"
        android:checked="true"
        android:fontFamily="sans-serif-medium"
        android:thumbTint="?attr/colorPrimary"
        android:trackTint="?attr/colorPrimary"
        app:layout_constraintTop_toBottomOf="@id/chipGroupTimeSignature"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp" />

    <!-- Indicadores de pulso -->
    <LinearLayout
        android:id="@+id/beatIndicators"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/switchAccentFirst"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón Start/Stop centrado -->
    <ImageButton
        android:id="@+id/btnStartStop"
        android:layout_width="97dp"
        android:layout_height="93dp"
        android:layout_marginTop="128dp"
        android:adjustViewBounds="true"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:src="@drawable/ic_play_24"
        android:tint="?attr/colorPrimary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/beatIndicators"
        android:contentDescription="Start/Stop" />
</androidx.constraintlayout.widget.ConstraintLayout>
