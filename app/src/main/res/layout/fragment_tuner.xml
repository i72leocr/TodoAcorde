<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F5F5F5">

    <!-- Círculo que muestra la nota detectada -->
    <View
        android:id="@+id/noteCircle"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_centerHorizontal="true"
        android:background="@drawable/circle_background"
        android:layout_marginTop="32dp"/>

    <!-- Texto dentro del círculo (nota) -->
    <TextView
        android:id="@+id/noteDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:text="E"
        android:textColor="@color/black"
        android:textSize="36sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/frequencyDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Frecuencia: 0.00 Hz"
        android:textSize="18sp"
        android:textColor="@android:color/black"
        android:layout_gravity="center_horizontal"/>
    <!-- Barra de afinación -->
    <SeekBar
        android:id="@+id/tuningBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/noteCircle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="32dp"
        android:max="100"
        android:progress="50"
        android:progressDrawable="@drawable/custom_progress_bar"
        android:thumb="@drawable/thumb_indicator" />

    <!-- Indicador de afinación -->
    <TextView
        android:id="@+id/tuningIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tuningBar"
        android:layout_marginTop="16dp"
        android:layout_centerHorizontal="true"
        android:text="Afinado"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"/>

    <!-- Acción de tensar o destensar -->
    <TextView
        android:id="@+id/tensionAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tuningIndicator"
        android:layout_marginTop="8dp"
        android:layout_centerHorizontal="true"
        android:text="TENSAR"
        android:textSize="16sp"
        android:textColor="@android:color/holo_red_dark"
        android:visibility="gone"/>

    <!-- Botón de inicio/detener -->
    <!-- Botón de micrófono (Start/Stop) -->
    <ImageButton
        android:id="@+id/btnMic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tensionAction"
        android:layout_marginTop="32dp"
        android:layout_centerHorizontal="true"
        android:background="?attr/selectableItemBackground"
        android:src="@android:drawable/ic_btn_speak_now"
        android:contentDescription="Microphone" />
</RelativeLayout>
