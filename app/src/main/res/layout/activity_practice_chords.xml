<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ImageButton
        android:id="@+id/back_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:src="@android:drawable/ic_menu_revert"
        android:contentDescription="Back" />

    <!-- Information Button at the top right corner -->
    <ImageButton
        android:id="@+id/btnInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="information"
        android:src="@android:drawable/ic_dialog_info"
        app:tint="@color/custom_color" />

    <!-- Selector de Modo (Aleatorio/Orden/Real) usando RadioGroup -->
    <RadioGroup
        android:id="@+id/radioGroupMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/back_button"
        android:layout_centerHorizontal="true"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <RadioButton
            android:id="@+id/radioOrder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modo Libre" />

        <RadioButton
            android:id="@+id/radioReal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modo Sincronizado" />
    </RadioGroup>

    <!-- Selector de velocidad (Aparece sólo en modo Real) -->
    <RadioGroup
        android:id="@+id/radioGroupSpeed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/radioGroupMode"
        android:layout_centerHorizontal="true"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <RadioButton
            android:id="@+id/radioSpeed1x"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Normal" />

        <RadioButton
            android:id="@+id/radioSpeed075x"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Moderada" />

        <RadioButton
            android:id="@+id/radioSpeed05x"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Suave" />
    </RadioGroup>

    <!-- Visualización del Acorde Actual -->
    <TextView
        android:id="@+id/tvCurrentChord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="36sp"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/radioGroupSpeed"
        android:layout_marginTop="16dp" />

    <!-- Detected Chord (small, next to the current chord) -->
    <TextView
        android:id="@+id/tvDetectedChord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:layout_toRightOf="@id/tvCurrentChord"
        android:layout_alignBaseline="@id/tvCurrentChord"
        android:layout_marginStart="8dp" />

    <!-- Custom Grid with Points View -->
    <com.tuguitar.todoacorde.GridWithPointsView
        android:id="@+id/gridWithPointsView"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_below="@id/tvCurrentChord"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:background="@android:color/white" />

    <!-- Indicador de Correcto/Fallo -->
    <TextView
        android:id="@+id/tvFeedback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="24sp"
        android:layout_below="@id/gridWithPointsView"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp" />

    <!-- Circular Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_below="@id/tvFeedback"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp" />


    <!-- Last Score -->
    <TextView
        android:id="@+id/tvLastScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/progressBar"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="Último Puntaje: 0"
        android:textSize="16sp"
        android:textColor="@android:color/darker_gray" />

    <!-- Best Score -->
    <TextView
        android:id="@+id/tvBestScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvLastScore"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="Mejor Puntaje: 0"
        android:textSize="18sp"
        android:textColor="@android:color/black" />

    <!-- Contenedor de las letras de la canción -->
    <LinearLayout
        android:id="@+id/lyrics_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:layout_below="@id/tvBestScore"
        tools:visibility="visible">
    </LinearLayout>

    <!-- Botón para Empezar/Terminar -->
    <Button
        android:id="@+id/btnStartStopPractice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/lyrics_container"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:padding="10dp"
        android:text="Terminar"
        android:textSize="20sp" />

</RelativeLayout>
