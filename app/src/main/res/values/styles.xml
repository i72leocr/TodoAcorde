<resources>
    <!-- 1) Tema principal: MaterialComponents -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <!-- Colores primarios -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Color secundario (accent) -->
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Para que los componentes Material usen tu paleta -->
        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button</item>
        <!-- … añade aquí cualquier otro override de MaterialComponents … -->


    </style>
    <style name="TabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="fontFamily">@font/roboto_mono_medium</item>
        <item name="android:textSize">14sp</item>
    </style>


    <!-- 2) Tema AppCompat antiguo, por compatibilidad -->
    <style name="AppTheme.AppCompat" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!-- styles.xml -->
    <style name="PracticeLineText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
        <item name="android:autoSizeTextType">uniform</item>
        <item name="android:autoSizeMinTextSize">8sp</item>
        <item name="android:autoSizeMaxTextSize">20sp</item>
        <item name="android:autoSizeStepGranularity">1sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@android:color/black</item>
    </style>


</resources>
